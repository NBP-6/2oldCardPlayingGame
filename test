
<style>
  @import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Crimson+Text:ital,wght@0,400;0,600;1,400&display=swap');

  * { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --ocean-deep: #0a1628;
    --ocean-mid: #0d2040;
    --ocean-surface: #112a52;
    --plank: #2c1a0e;
    --plank-light: #3d2512;
    --gold: #c9a84c;
    --gold-light: #e8c96a;
    --gold-dim: #8a6e2f;
    --teal: #1d9e75;
    --teal-light: #5dcaa5;
    --red: #c0392b;
    --red-light: #e74c3c;
    --purple: #7f77dd;
    --purple-light: #afa9ec;
    --amber: #ef9f27;
    --text-bright: #f0e6c8;
    --text-dim: #8a7a5a;
    --border-gold: rgba(201,168,76,0.3);
    --card-bg: #1a2e4a;
    --card-border: rgba(201,168,76,0.4);
    --hp-ship: #1d9e75;
    --hp-pirate: #e74c3c;
  }

  #game-root {
    font-family: 'Crimson Text', serif;
    background: var(--ocean-deep);
    color: var(--text-bright);
    min-height: 600px;
    padding: 12px;
    position: relative;
    overflow: hidden;
  }

  #game-root::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 0%, rgba(13,32,64,0.8) 0%, transparent 70%),
                repeating-linear-gradient(0deg, transparent, transparent 60px, rgba(255,255,255,0.01) 60px, rgba(255,255,255,0.01) 61px);
    pointer-events: none;
  }

  .screen { display: none; flex-direction: column; align-items: center; width: 100%; }
  .screen.active { display: flex; }

  /* TITLE SCREEN */
  #title-screen {
    justify-content: center;
    min-height: 580px;
    gap: 24px;
    padding: 40px 20px;
  }

  .title-logo {
    font-family: 'Cinzel', serif;
    font-size: 13px;
    letter-spacing: 8px;
    color: var(--gold-dim);
    text-transform: uppercase;
    margin-bottom: -12px;
  }

  .title-main {
    font-family: 'Cinzel', serif;
    font-size: 36px;
    font-weight: 700;
    color: var(--gold-light);
    text-align: center;
    line-height: 1.1;
    text-shadow: 0 0 40px rgba(201,168,76,0.3);
  }

  .title-sub {
    font-size: 16px;
    color: var(--text-dim);
    font-style: italic;
    letter-spacing: 2px;
  }

  .divider {
    width: 200px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--gold-dim), transparent);
  }

  .btn-start {
    font-family: 'Cinzel', serif;
    font-size: 14px;
    letter-spacing: 3px;
    padding: 14px 48px;
    background: transparent;
    border: 1px solid var(--gold);
    color: var(--gold-light);
    cursor: pointer;
    text-transform: uppercase;
    transition: all 0.2s;
    margin-top: 8px;
  }
  .btn-start:hover { background: rgba(201,168,76,0.1); box-shadow: 0 0 20px rgba(201,168,76,0.2); }

  /* GAME SCREEN */
  #game-screen {
    min-height: 600px;
    width: 100%;
    gap: 8px;
    padding: 4px 0;
  }

  /* BATTLEFIELD */
  .battlefield {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .player-zone {
    width: 100%;
    padding: 10px 12px;
    background: rgba(17,42,82,0.6);
    border: 1px solid var(--border-gold);
    border-radius: 8px;
    position: relative;
  }

  .player-zone.enemy { border-color: rgba(192,57,43,0.3); }
  .player-zone.player { border-color: rgba(29,158,117,0.3); }

  .zone-label {
    font-family: 'Cinzel', serif;
    font-size: 10px;
    letter-spacing: 3px;
    color: var(--text-dim);
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  .hp-row {
    display: flex;
    gap: 16px;
    align-items: center;
    margin-bottom: 6px;
    flex-wrap: wrap;
  }

  .hp-block {
    display: flex;
    flex-direction: column;
    gap: 3px;
    min-width: 100px;
  }

  .hp-label {
    font-size: 11px;
    color: var(--text-dim);
    letter-spacing: 1px;
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .hp-bar-wrap {
    height: 8px;
    background: rgba(0,0,0,0.4);
    border-radius: 4px;
    overflow: hidden;
    width: 120px;
    border: 1px solid rgba(255,255,255,0.1);
  }

  .hp-bar-fill {
    height: 100%;
    border-radius: 4px;
    transition: width 0.4s ease;
  }

  .hp-val {
    font-family: 'Cinzel', serif;
    font-size: 13px;
    font-weight: 600;
  }

  .ship-fill { background: var(--hp-ship); }
  .pirate-fill { background: var(--hp-pirate); }
  .ship-val { color: var(--teal-light); }
  .pirate-val { color: var(--red-light); }

  /* STATUS EFFECTS */
  .status-row {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    min-height: 20px;
  }

  .status-badge {
    font-size: 10px;
    padding: 2px 8px;
    border-radius: 10px;
    font-family: 'Cinzel', serif;
    letter-spacing: 1px;
  }
  .status-drunk { background: rgba(127,119,221,0.3); color: var(--purple-light); border: 1px solid var(--purple); }
  .status-skip { background: rgba(192,57,43,0.3); color: #e87c7c; border: 1px solid var(--red); }
  .status-scatter { background: rgba(239,159,39,0.3); color: #f5c875; border: 1px solid var(--amber); }

  /* ACTIVE EFFECTS TABLE */
  .effects-row {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .effect-chip {
    font-size: 10px;
    padding: 2px 7px;
    border-radius: 4px;
    background: rgba(239,159,39,0.15);
    border: 1px solid rgba(239,159,39,0.3);
    color: #f5c875;
  }

  /* MIDDLE BAR */
  .battle-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 12px;
    background: rgba(10,22,40,0.8);
    border-radius: 6px;
    border: 1px solid var(--border-gold);
  }

  .turn-indicator {
    font-family: 'Cinzel', serif;
    font-size: 11px;
    letter-spacing: 2px;
    color: var(--gold);
    text-transform: uppercase;
  }

  .mana-display {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .mana-label {
    font-size: 11px;
    color: var(--text-dim);
  }

  .mana-pips {
    display: flex;
    gap: 4px;
  }

  .mana-pip {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: 1px solid var(--gold);
    transition: background 0.2s;
  }

  .mana-pip.full { background: var(--gold); box-shadow: 0 0 6px rgba(201,168,76,0.5); }
  .mana-pip.empty { background: transparent; }

  .end-turn-btn {
    font-family: 'Cinzel', serif;
    font-size: 10px;
    letter-spacing: 2px;
    padding: 6px 16px;
    background: transparent;
    border: 1px solid var(--gold-dim);
    color: var(--gold);
    cursor: pointer;
    text-transform: uppercase;
    transition: all 0.2s;
    border-radius: 4px;
  }
  .end-turn-btn:hover { background: rgba(201,168,76,0.1); }
  .end-turn-btn:disabled { opacity: 0.3; cursor: not-allowed; }

  /* HAND */
  .hand-section {
    width: 100%;
    padding: 8px 12px;
    background: rgba(26,46,74,0.5);
    border: 1px solid var(--border-gold);
    border-radius: 8px;
  }

  .hand-label {
    font-family: 'Cinzel', serif;
    font-size: 10px;
    letter-spacing: 3px;
    color: var(--text-dim);
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  .hand-cards {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  /* CARD */
  .card {
    width: 90px;
    min-height: 120px;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 6px;
    padding: 6px;
    cursor: pointer;
    transition: transform 0.15s, border-color 0.15s, box-shadow 0.15s;
    display: flex;
    flex-direction: column;
    gap: 3px;
    position: relative;
    flex-shrink: 0;
  }

  .card:hover:not(.unaffordable):not(.disabled) {
    transform: translateY(-6px);
    border-color: var(--gold);
    box-shadow: 0 8px 20px rgba(0,0,0,0.5);
  }

  .card.unaffordable { opacity: 0.4; cursor: not-allowed; }
  .card.disabled { opacity: 0.5; cursor: not-allowed; }

  .card-cost {
    position: absolute;
    top: 4px;
    right: 5px;
    font-family: 'Cinzel', serif;
    font-size: 11px;
    font-weight: 700;
    color: var(--gold-light);
    width: 18px;
    height: 18px;
    background: rgba(0,0,0,0.5);
    border: 1px solid var(--gold-dim);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-icon {
    font-size: 22px;
    text-align: center;
    padding: 4px 0;
    line-height: 1;
  }

  .card-name {
    font-family: 'Cinzel', serif;
    font-size: 9px;
    font-weight: 600;
    color: var(--gold-light);
    text-align: center;
    letter-spacing: 0.5px;
    line-height: 1.2;
  }

  .card-type {
    font-size: 9px;
    color: var(--text-dim);
    text-align: center;
    font-style: italic;
  }

  .card-desc {
    font-size: 9px;
    color: var(--text-bright);
    text-align: center;
    line-height: 1.4;
    margin-top: 2px;
    opacity: 0.9;
  }

  /* card type borders */
  .card.attack { border-color: rgba(192,57,43,0.5); }
  .card.attack:hover:not(.unaffordable) { border-color: var(--red-light); box-shadow: 0 8px 20px rgba(192,57,43,0.3); }
  .card.defense { border-color: rgba(29,158,117,0.5); }
  .card.defense:hover:not(.unaffordable) { border-color: var(--teal-light); box-shadow: 0 8px 20px rgba(29,158,117,0.3); }
  .card.curse { border-color: rgba(127,119,221,0.5); }
  .card.curse:hover:not(.unaffordable) { border-color: var(--purple-light); box-shadow: 0 8px 20px rgba(127,119,221,0.3); }
  .card.food { border-color: rgba(239,159,39,0.4); }
  .card.food:hover:not(.unaffordable) { border-color: var(--amber); box-shadow: 0 8px 20px rgba(239,159,39,0.3); }
  .card.utility { border-color: rgba(201,168,76,0.4); }

  /* LOG */
  .battle-log {
    width: 100%;
    padding: 8px 12px;
    background: rgba(10,22,40,0.7);
    border: 1px solid var(--border-gold);
    border-radius: 6px;
    max-height: 90px;
    overflow-y: auto;
  }

  .log-entry {
    font-size: 12px;
    color: var(--text-dim);
    line-height: 1.6;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    padding: 1px 0;
  }

  .log-entry:last-child { color: var(--text-bright); border-bottom: none; }
  .log-dmg { color: #e87c7c; }
  .log-heal { color: var(--teal-light); }
  .log-curse { color: var(--purple-light); }
  .log-sys { color: var(--gold-dim); font-style: italic; }

  /* GAME OVER */
  #gameover-screen {
    justify-content: center;
    min-height: 580px;
    gap: 20px;
  }

  .gameover-title {
    font-family: 'Cinzel', serif;
    font-size: 32px;
    font-weight: 700;
    text-align: center;
  }

  .gameover-title.win { color: var(--gold-light); text-shadow: 0 0 30px rgba(201,168,76,0.4); }
  .gameover-title.lose { color: var(--red-light); text-shadow: 0 0 30px rgba(192,57,43,0.4); }

  .gameover-sub {
    font-size: 16px;
    color: var(--text-dim);
    font-style: italic;
    text-align: center;
  }

  .dice-result {
    font-family: 'Cinzel', serif;
    font-size: 13px;
    padding: 8px 16px;
    background: rgba(127,119,221,0.2);
    border: 1px solid var(--purple);
    border-radius: 6px;
    color: var(--purple-light);
    text-align: center;
  }

  .ai-thinking {
    font-family: 'Cinzel', serif;
    font-size: 10px;
    letter-spacing: 2px;
    color: var(--red-light);
    text-align: center;
    opacity: 0.7;
  }

  /* deck count */
  .deck-info {
    font-size: 10px;
    color: var(--text-dim);
    display: flex;
    align-items: center;
    gap: 8px;
  }
</style>

<div id="game-root">
  <h2 class="sr-only">Sea of Thieves Hourglass Card Game — playable 1v1 vs AI opponent</h2>

  <!-- TITLE -->
  <div id="title-screen" class="screen active">
    <p class="title-logo">Sea of Thieves</p>
    <h1 class="title-main">Hourglass<br>Card Game</h1>
    <p class="title-sub">One ship. One battle. No mercy.</p>
    <div class="divider"></div>
    <div style="font-size:13px; color:var(--text-dim); max-width:320px; text-align:center; line-height:1.8;">
      You are a pirate captain in the Hourglass of Fate. Sink the enemy ship before yours goes under.<br><br>
      <span style="color:var(--teal-light)">Ship HP</span> — your win condition &nbsp;|&nbsp; <span style="color:var(--red-light)">Pirate HP</span> — protect your crew
    </div>
    <button class="btn-start" onclick="startGame()">Raise Anchor</button>
    <div style="font-size:11px; color:var(--text-dim); text-align:center; line-height:1.8; margin-top:8px;">
      3 energy per turn &nbsp;·&nbsp; Draw 2 per turn &nbsp;·&nbsp; Opponent: Semi-Smart AI
    </div>
  </div>

  <!-- GAME -->
  <div id="game-screen" class="screen">
    <div class="battlefield">

      <!-- ENEMY ZONE -->
      <div class="player-zone enemy" id="enemy-zone">
        <div class="zone-label">Enemy Ship — The Reaper's Tide</div>
        <div class="hp-row">
          <div class="hp-block">
            <div class="hp-label">⚓ Ship</div>
            <div style="display:flex;align-items:center;gap:8px;">
              <div class="hp-bar-wrap"><div class="hp-bar-fill ship-fill" id="e-ship-bar" style="width:100%"></div></div>
              <span class="hp-val ship-val" id="e-ship-val">20</span>
            </div>
          </div>
          <div class="hp-block">
            <div class="hp-label">☠ Pirate</div>
            <div style="display:flex;align-items:center;gap:8px;">
              <div class="hp-bar-wrap"><div class="hp-bar-fill pirate-fill" id="e-pirate-bar" style="width:100%"></div></div>
              <span class="hp-val pirate-val" id="e-pirate-val">10</span>
            </div>
          </div>
          <div style="margin-left:auto;" class="deck-info">
            <span id="e-deck-count">Deck: 20</span>
          </div>
        </div>
        <div class="status-row" id="e-status-row"></div>
        <div class="effects-row" id="e-effects-row"></div>
      </div>

      <!-- BATTLE BAR -->
      <div class="battle-bar">
        <div class="turn-indicator" id="turn-label">Your Turn — Round 1</div>
        <div class="mana-display">
          <span class="mana-label">Energy:</span>
          <div class="mana-pips" id="mana-pips"></div>
          <span style="font-size:11px;color:var(--gold);margin-left:4px;" id="mana-text">3/3</span>
        </div>
        <button class="end-turn-btn" id="end-turn-btn" onclick="endTurn()">End Turn</button>
      </div>

      <!-- PLAYER ZONE -->
      <div class="player-zone player" id="player-zone">
        <div class="zone-label">Your Ship — The Sea Dog</div>
        <div class="hp-row">
          <div class="hp-block">
            <div class="hp-label">⚓ Ship</div>
            <div style="display:flex;align-items:center;gap:8px;">
              <div class="hp-bar-wrap"><div class="hp-bar-fill ship-fill" id="p-ship-bar" style="width:100%"></div></div>
              <span class="hp-val ship-val" id="p-ship-val">20</span>
            </div>
          </div>
          <div class="hp-block">
            <div class="hp-label">☠ Pirate</div>
            <div style="display:flex;align-items:center;gap:8px;">
              <div class="hp-bar-wrap"><div class="hp-bar-fill pirate-fill" id="p-pirate-bar" style="width:100%"></div></div>
              <span class="hp-val pirate-val" id="p-pirate-val">10</span>
            </div>
          </div>
          <div style="margin-left:auto;" class="deck-info">
            <span id="p-deck-count">Deck: 20</span>
          </div>
        </div>
        <div class="status-row" id="p-status-row"></div>
        <div class="effects-row" id="p-effects-row"></div>
      </div>

    </div>

    <!-- LOG -->
    <div class="battle-log" id="battle-log">
      <div class="log-entry log-sys">The battle begins. Man your cannons!</div>
    </div>

    <!-- HAND -->
    <div class="hand-section">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
        <div class="hand-label">Your Hand</div>
        <span id="ai-thinking-label" class="ai-thinking" style="display:none;">Enemy is planning...</span>
      </div>
      <div class="hand-cards" id="hand-cards"></div>
    </div>

  </div>

  <!-- GAME OVER -->
  <div id="gameover-screen" class="screen">
    <div class="divider"></div>
    <div class="gameover-title" id="go-title">Victory!</div>
    <div class="gameover-sub" id="go-sub">The enemy ship sinks beneath the waves.</div>
    <div class="divider"></div>
    <button class="btn-start" onclick="startGame()">Fight Again</button>
  </div>

</div>

<script>
const CARDS = [
  { id:'cannonball', name:'Cannonball', type:'attack', cost:1, icon:'💣', desc:'Deal 2 dmg to enemy ship.', effect:(p,e,gs)=>{ dmgShip(e,'enemy',2,gs); } },
  { id:'heavy_shot', name:'Heavy Shot', type:'attack', cost:2, icon:'🔴', desc:'Deal 4 dmg to enemy ship.', effect:(p,e,gs)=>{ dmgShip(e,'enemy',4,gs); } },
  { id:'scattershot', name:'Scattershot', type:'attack', cost:2, icon:'💥', desc:'3 dmg over 3 turns.', effect:(p,e,gs)=>{ addDelayed(e,'scatter',3,gs); } },
  { id:'snipe', name:'Long Snipe', type:'attack', cost:2, icon:'🎯', desc:'Deal 3 dmg. Ignores defenses.', effect:(p,e,gs)=>{ dmgShipRaw(e,'enemy',3,gs); } },
  { id:'chainshot', name:'Chainshot', type:'curse', cost:2, icon:'⛓️', desc:'Dismast enemy. They skip next turn.', effect:(p,e,gs)=>{ addStatus(e,'skip',1,gs,'enemy'); } },
  { id:'grog_ball', name:'Grog Ball', type:'curse', cost:2, icon:'🍺', desc:'Enemy drunk. 50% miss chance 2 turns.', effect:(p,e,gs)=>{ addStatus(e,'drunk',2,gs,'enemy'); } },
  { id:'ballast_ball', name:'Ballast Ball', type:'curse', cost:3, icon:'⚫', desc:'Huge impact! 6 dmg to enemy ship.', effect:(p,e,gs)=>{ dmgShip(e,'enemy',6,gs); } },
  { id:'boarding', name:'Boarding', type:'curse', cost:3, icon:'🏴‍☠️', desc:'Board enemy! 3 pirate dmg + skip turn.', effect:(p,e,gs)=>{ dmgPirate(e,'enemy',3,gs); addStatus(e,'skip',1,gs,'enemy'); } },
  { id:'plank', name:'Plank', type:'defense', cost:1, icon:'🪵', desc:'Repair ship +2 HP.', effect:(p,e,gs)=>{ healShip(p,'player',2,gs); } },
  { id:'emergency_repair', name:'Emerg. Repair', type:'defense', cost:2, icon:'🔧', desc:'Repair ship +4 HP.', effect:(p,e,gs)=>{ healShip(p,'player',4,gs); } },
  { id:'bail', name:'Bail Water', type:'defense', cost:1, icon:'🪣', desc:'Block next 2 incoming ship dmg.', effect:(p,e,gs)=>{ addStatus(p,'shield',2,gs,'player'); } },
  { id:'banana', name:'Banana', type:'food', cost:1, icon:'🍌', desc:'Restore +2 pirate HP.', effect:(p,e,gs)=>{ healPirate(p,'player',2,gs); } },
  { id:'pineapple', name:'Pineapple', type:'food', cost:1, icon:'🍍', desc:'Restore +3 pirate HP.', effect:(p,e,gs)=>{ healPirate(p,'player',3,gs); } },
  { id:'cooked_meat', name:'Cooked Meat', type:'food', cost:2, icon:'🍖', desc:'Restore +5 pirate HP.', effect:(p,e,gs)=>{ healPirate(p,'player',5,gs); } },
  { id:'fruit_crate', name:'Fruit Crate', type:'food', cost:3, icon:'📦', desc:'+8 pirate HP + draw 1.', effect:(p,e,gs)=>{ healPirate(p,'player',8,gs); gs.drawCards('player',1); } },
  { id:'grog_drink', name:'Grog', type:'food', cost:1, icon:'🥃', desc:'Draw 2 cards, -1 pirate HP.', effect:(p,e,gs)=>{ gs.drawCards('player',2); dmgPirate(p,'player',1,gs); } },
  { id:'raise_sails', name:'Raise Sails', type:'utility', cost:1, icon:'⛵', desc:'+2 energy next turn.', effect:(p,e,gs)=>{ gs.bonusEnergy+=2; log('You raise the sails! +2 energy next turn.','log-sys'); } },
  { id:'favorable_wind', name:'Favorable Wind', type:'utility', cost:0, icon:'💨', desc:'Discard 1 random card, +1 energy now.', effect:(p,e,gs)=>{ gs.mana+=1; gs.updateMana(); if(gs.playerHand.length>0){ const i=Math.floor(Math.random()*gs.playerHand.length); const disc=gs.playerHand.splice(i,1)[0]; log(`Wind blows! Discarded ${disc.name}, gained +1 energy.`,'log-sys'); gs.renderHand(); } } },
  { id:'crew_orders', name:'Crew Orders', type:'utility', cost:2, icon:'📜', desc:'Draw 3 cards.', effect:(p,e,gs)=>{ gs.drawCards('player',3); } },
  { id:'ships_cook', name:"Ship's Cook", type:'utility', cost:2, icon:'👨‍🍳', desc:'Draw 1 card + restore +2 pirate HP.', effect:(p,e,gs)=>{ gs.drawCards('player',1); healPirate(p,'player',2,gs); } },
];

const SHIP_MAX=20, PIRATE_MAX=10;

function log(msg,cls=''){
  const el=document.getElementById('battle-log');
  const d=document.createElement('div');
  d.className='log-entry '+(cls||'');
  d.textContent=msg;
  el.appendChild(d);
  el.scrollTop=el.scrollHeight;
}

function clamp(v,mn,mx){ return Math.max(mn,Math.min(mx,v)); }

function dmgShip(target,who,amt,gs){
  if(target.shieldTurns>0){ target.shieldTurns=Math.max(0,target.shieldTurns-amt); amt=0; log(`${who==='player'?'Your':'Enemy'} bail absorbs the hit!`,'log-sys'); }
  if(amt<=0) return;
  target.shipHP=clamp(target.shipHP-amt,0,SHIP_MAX);
  log(`${who==='player'?'Your ship takes':'Enemy ship takes'} ${amt} hull damage! (${target.shipHP} HP left)`,'log-dmg');
  gs.updateUI();
}

function dmgShipRaw(target,who,amt,gs){
  target.shipHP=clamp(target.shipHP-amt,0,SHIP_MAX);
  log(`${who==='player'?'Your ship takes':'Enemy ship takes'} ${amt} hull damage! (${target.shipHP} HP left)`,'log-dmg');
  gs.updateUI();
}

function dmgPirate(target,who,amt,gs){
  target.pirateHP=clamp(target.pirateHP-amt,0,PIRATE_MAX);
  log(`${who==='player'?'Your pirate':'Enemy pirate'} takes ${amt} damage! (${target.pirateHP} HP left)`,'log-dmg');
  if(target.pirateHP<=0){
    target.pirateHP=5; log(`${who==='player'?'Your pirate':'Enemy pirate'} respawns with 5 HP — but loses tempo!`,'log-sys');
    addStatus(target,'skip',1,gs,who);
    gs.updateUI();
  }
  gs.updateUI();
}

function healShip(target,who,amt,gs){
  const prev=target.shipHP; target.shipHP=clamp(target.shipHP+amt,0,SHIP_MAX);
  log(`${who==='player'?'Your ship':'Enemy ship'} repaired +${target.shipHP-prev} HP. (${target.shipHP}/${SHIP_MAX})`,'log-heal');
  gs.updateUI();
}

function healPirate(target,who,amt,gs){
  const prev=target.pirateHP; target.pirateHP=clamp(target.pirateHP+amt,0,PIRATE_MAX);
  log(`${who==='player'?'Your pirate':'Enemy pirate'} healed +${target.pirateHP-prev} HP. (${target.pirateHP}/${PIRATE_MAX})`,'log-heal');
  gs.updateUI();
}

function addStatus(target,type,turns,gs,who){
  if(type==='drunk'){ target.drunkTurns=turns; log(`${who==='player'?'Your crew is':'Enemy crew is'} drunk! 50% miss for ${turns} turns.`,'log-curse'); }
  if(type==='skip'){ target.skipTurns+=1; log(`${who==='player'?'Your ship is':'Enemy ship is'} dismasted/boarded! Skip next turn.`,'log-curse'); }
  if(type==='shield'){ target.shieldTurns+=turns; log(`${who==='player'?'Your':'Enemy'} crew bails water — ${turns} dmg absorbed!`,'log-heal'); }
  gs.renderStatuses();
}

function addDelayed(target,type,turns,gs){
  if(type==='scatter'){ target.scatterTurns=turns; log(`Scattershot lands! 1 dmg per turn for ${turns} turns.`,'log-curse'); }
  gs.renderStatuses();
}

function buildDeck(){
  const pool=['cannonball','cannonball','cannonball','heavy_shot','heavy_shot','scattershot','scattershot',
    'snipe','chainshot','grog_ball','ballast_ball','boarding',
    'plank','plank','plank','emergency_repair','bail','bail',
    'banana','banana','pineapple','pineapple','cooked_meat','fruit_crate','grog_drink',
    'raise_sails','raise_sails','favorable_wind','crew_orders','ships_cook'];
  const deck=pool.map(id=>({...CARDS.find(c=>c.id===id)}));
  for(let i=deck.length-1;i>0;i--){ const j=Math.floor(Math.random()*(i+1)); [deck[i],deck[j]]=[deck[j],deck[i]]; }
  return deck;
}

let GS=null;

function startGame(){
  GS={
    round:1,
    turn:'player',
    mana:3,
    maxMana:3,
    bonusEnergy:0,
    playerHand:[],
    enemyHand:[],
    playerDeck:buildDeck(),
    enemyDeck:buildDeck(),
    player:{ shipHP:SHIP_MAX, pirateHP:PIRATE_MAX, drunkTurns:0, skipTurns:0, shieldTurns:0, scatterTurns:0 },
    enemy:{ shipHP:SHIP_MAX, pirateHP:PIRATE_MAX, drunkTurns:0, skipTurns:0, shieldTurns:0, scatterTurns:0 },

    drawCards(who, n){
      for(let i=0;i<n;i++){
        if(who==='player'){
          if(this.playerDeck.length===0){ log('Your deck is empty! Shuffling discard...','log-sys'); this.playerDeck=buildDeck(); }
          const c=this.playerDeck.pop(); this.playerHand.push(c);
        } else {
          if(this.enemyDeck.length===0){ this.enemyDeck=buildDeck(); }
          this.enemyDeck.pop(); // enemy hand not shown
          this.enemyHand.push({...CARDS[Math.floor(Math.random()*CARDS.length)]});
        }
      }
      this.renderHand();
      this.updateDeckCounts();
    },

    updateMana(){
      const pips=document.getElementById('mana-pips');
      pips.innerHTML='';
      for(let i=0;i<this.maxMana;i++){
        const p=document.createElement('div');
        p.className='mana-pip '+(i<this.mana?'full':'empty');
        pips.appendChild(p);
      }
      document.getElementById('mana-text').textContent=`${this.mana}/${this.maxMana}`;
    },

    updateUI(){
      const ps=this.player, es=this.enemy;
      document.getElementById('p-ship-val').textContent=ps.shipHP;
      document.getElementById('e-ship-val').textContent=es.shipHP;
      document.getElementById('p-pirate-val').textContent=ps.pirateHP;
      document.getElementById('e-pirate-val').textContent=es.pirateHP;
      document.getElementById('p-ship-bar').style.width=(ps.shipHP/SHIP_MAX*100)+'%';
      document.getElementById('e-ship-bar').style.width=(es.shipHP/SHIP_MAX*100)+'%';
      document.getElementById('p-pirate-bar').style.width=(ps.pirateHP/PIRATE_MAX*100)+'%';
      document.getElementById('e-pirate-bar').style.width=(es.pirateHP/PIRATE_MAX*100)+'%';
      this.renderStatuses();
      this.checkGameOver();
    },

    updateDeckCounts(){
      document.getElementById('p-deck-count').textContent=`Deck: ${this.playerDeck.length}`;
      document.getElementById('e-deck-count').textContent=`Deck: ${this.enemyDeck.length}`;
    },

    renderStatuses(){
      ['player','enemy'].forEach(who=>{
        const t=who==='player'?this.player:this.enemy;
        const sr=document.getElementById((who==='player'?'p':'e')+'-status-row');
        const er=document.getElementById((who==='player'?'p':'e')+'-effects-row');
        sr.innerHTML='';
        er.innerHTML='';
        if(t.drunkTurns>0){ sr.innerHTML+=`<span class="status-badge status-drunk">Drunk (${t.drunkTurns})</span>`; }
        if(t.skipTurns>0){ sr.innerHTML+=`<span class="status-badge status-skip">Dismasted (${t.skipTurns})</span>`; }
        if(t.shieldTurns>0){ er.innerHTML+=`<span class="effect-chip">⛨ Shield ${t.shieldTurns}</span>`; }
        if(t.scatterTurns>0){ er.innerHTML+=`<span class="effect-chip">💥 Scatter (${t.scatterTurns} turns)</span>`; }
      });
    },

    renderHand(){
      const hc=document.getElementById('hand-cards');
      hc.innerHTML='';
      if(this.turn!=='player'){ return; }
      this.playerHand.forEach((card,idx)=>{
        const canAfford=this.mana>=card.cost;
        const div=document.createElement('div');
        div.className=`card ${card.type}${!canAfford?' unaffordable':''}`;
        div.innerHTML=`<div class="card-cost">${card.cost}</div><div class="card-icon">${card.icon}</div><div class="card-name">${card.name}</div><div class="card-type">${card.type}</div><div class="card-desc">${card.desc}</div>`;
        if(canAfford && this.turn==='player'){
          div.onclick=()=>this.playCard(idx);
        }
        hc.appendChild(div);
      });
    },

    playCard(idx){
      if(this.turn!=='player') return;
      const card=this.playerHand[idx];
      if(this.mana<card.cost){ log("Not enough energy!",'log-sys'); return; }
      this.mana-=card.cost;
      this.updateMana();
      this.playerHand.splice(idx,1);
      log(`You play: ${card.name}`,'');
      card.effect(this.player, this.enemy, this);
      this.renderHand();
      this.updateUI();
    },

    resolveDelayed(who){
      const t=who==='player'?this.player:this.enemy;
      const label=who==='player'?'Your ship':'Enemy ship';
      if(t.scatterTurns>0){
        t.scatterTurns--;
        if(who==='player'){ dmgShipRaw(t,'player',1,this); log(`Scattershot hits! ${label} -1 HP.`,'log-dmg'); }
        else { dmgShipRaw(t,'enemy',1,this); log(`Scattershot hits! ${label} -1 HP.`,'log-dmg'); }
      }
    },

    checkGameOver(){
      if(this.player.shipHP<=0){
        showGameOver(false,'Your ship sinks beneath the waves. The enemy claims victory.');
        return true;
      }
      if(this.enemy.shipHP<=0){
        showGameOver(true,'The enemy ship breaks apart! You claim the seas!');
        return true;
      }
      return false;
    },

    aiTurn(){
      const ai=document.getElementById('ai-thinking-label');
      ai.style.display='block';
      document.getElementById('end-turn-btn').disabled=true;

      let delay=600;
      const doPlay=()=>{
        if(this.checkGameOver()) return;
        if(this.enemyHand.length===0 || this.mana<=0){
          setTimeout(()=>this.endAiTurn(),400);
          return;
        }

        const ps=this.player, es=this.enemy;
        const affordable=this.enemyHand.filter(c=>c.cost<=this.mana);
        if(affordable.length===0){ setTimeout(()=>this.endAiTurn(),400); return; }

        let chosen;
        const isWinning = es.shipHP >= ps.shipHP;
        const pirateHurt = es.pirateHP <= 4;
        const shipHurt = es.shipHP <= 8;

        if(shipHurt){ const repairs=affordable.filter(c=>c.type==='defense'||c.type==='food'); if(repairs.length){ chosen=repairs[Math.floor(Math.random()*repairs.length)]; } }
        if(!chosen && pirateHurt){ const food=affordable.filter(c=>c.type==='food'); if(food.length){ chosen=food[Math.floor(Math.random()*food.length)]; } }
        if(!chosen && isWinning){ const atk=affordable.filter(c=>c.type==='attack'||c.type==='curse'); if(atk.length){ chosen=atk[Math.floor(Math.random()*atk.length)]; } }
        if(!chosen){ chosen=affordable[Math.floor(Math.random()*affordable.length)]; }

        const cidx=this.enemyHand.indexOf(chosen);
        this.enemyHand.splice(cidx,1);
        this.mana-=chosen.cost;
        this.updateMana();
        log(`Enemy plays: ${chosen.name} ${chosen.icon}`,'log-dmg');

        // Execute effect from enemy perspective (swap player/enemy)
        chosen.effect(this.enemy, this.player, {
          ...this,
          drawCards:(who,n)=>{ if(who==='player'){ for(let i=0;i<n;i++){ this.enemyHand.push({...CARDS[Math.floor(Math.random()*CARDS.length)]}); } log(`Enemy draws ${n} card(s).`,'log-sys'); } },
          bonusEnergy:0,
          mana:this.mana,
          updateMana:()=>this.updateMana(),
          renderHand:()=>this.renderHand(),
          renderStatuses:()=>this.renderStatuses(),
          updateUI:()=>this.updateUI(),
        });

        this.updateUI();
        if(this.checkGameOver()) return;
        delay=700;
        setTimeout(doPlay, delay);
      };

      setTimeout(doPlay, delay);
    },

    endAiTurn(){
      document.getElementById('ai-thinking-label').style.display='none';
      this.resolveDelayed('player');
      if(this.checkGameOver()) return;
      if(this.player.skipTurns>0){
        this.player.skipTurns--;
        log('Your ship is dismasted! Turn skipped.','log-curse');
        this.renderStatuses();
        // enemy gets another turn
        this.round++;
        this.mana=this.maxMana;
        this.updateMana();
        this.resolveDelayed('enemy');
        this.drawCards('enemy',2);
        document.getElementById('turn-label').textContent=`Enemy Turn — Round ${this.round}`;
        setTimeout(()=>this.aiTurn(),800);
        return;
      }
      this.round++;
      this.mana=this.maxMana+this.bonusEnergy;
      this.bonusEnergy=0;
      this.maxMana=3;
      if(this.player.drunkTurns>0) this.player.drunkTurns--;
      if(this.enemy.drunkTurns>0) this.enemy.drunkTurns--;
      this.updateMana();
      this.turn='player';
      document.getElementById('turn-label').textContent=`Your Turn — Round ${this.round}`;
      document.getElementById('end-turn-btn').disabled=false;
      this.drawCards('player',2);
      this.renderHand();
      log(`--- Round ${this.round} — Your turn ---`,'log-sys');
    },
  };

  // draw starting hands
  GS.drawCards('player',5);
  GS.drawCards('enemy',5);
  GS.updateUI();
  GS.updateMana();
  GS.updateDeckCounts();

  document.getElementById('battle-log').innerHTML='<div class="log-entry log-sys">The battle begins! Man your cannons!</div>';
  document.getElementById('turn-label').textContent='Your Turn — Round 1';

  showScreen('game-screen');
}

function endTurn(){
  if(!GS || GS.turn!=='player') return;
  GS.turn='enemy';
  document.getElementById('end-turn-btn').disabled=true;
  GS.resolveDelayed('enemy');
  if(GS.checkGameOver()) return;
  if(GS.enemy.skipTurns>0){
    GS.enemy.skipTurns--;
    log('Enemy ship is dismasted! Enemy skips their turn.','log-curse');
    GS.renderStatuses();
    GS.endAiTurn();
    return;
  }
  GS.mana=GS.maxMana;
  GS.updateMana();
  GS.drawCards('enemy',2);
  document.getElementById('turn-label').textContent=`Enemy Turn — Round ${GS.round}`;
  GS.renderHand();
  log(`--- Enemy turn ---`,'log-sys');
  setTimeout(()=>GS.aiTurn(),500);
}

function showGameOver(win, msg){
  const t=document.getElementById('go-title');
  t.textContent=win?'Victory!':'Defeat!';
  t.className='gameover-title '+(win?'win':'lose');
  document.getElementById('go-sub').textContent=msg;
  setTimeout(()=>showScreen('gameover-screen'),800);
}

function showScreen(id){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}
</script>
